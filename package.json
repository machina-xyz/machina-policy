{
  "name": "@machina/policy",
  "version": "0.1.0",
  "description": "MACHINA Policy Engine — governance for agent payments. Budget limits, approval chains, compliance, audit trails. Works with any wallet, protocol, or chain.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./engine": {
      "types": "./dist/engine.d.ts",
      "import": "./dist/engine.js"
    },
    "./budget": {
      "types": "./dist/budget.d.ts",
      "import": "./dist/budget.js"
    },
    "./approval": {
      "types": "./dist/approval.d.ts",
      "import": "./dist/approval.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "import": "./dist/middleware/index.js"
    },
    "./middleware/hono": {
      "types": "./dist/middleware/hono.d.ts",
      "import": "./dist/middleware/hono.js"
    },
    "./middleware/express": {
      "types": "./dist/middleware/express.d.ts",
      "import": "./dist/middleware/express.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "machina",
    "policy-engine",
    "governance",
    "ai-agent",
    "budget",
    "approval",
    "compliance",
    "middleware",
    "x402",
    "mpp",
    "hono",
    "express"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/machina/machina.git",
    "directory": "packages/policy"
  },
  "homepage": "https://machina.money",
  "devDependencies": {
    "@types/express": "^5.0.0",
    "hono": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0",
    "hono": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  }
}
